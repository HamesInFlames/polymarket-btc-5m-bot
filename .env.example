# === Copy to .env and fill secrets (never commit .env) ===

# --- Wallet / CLOB (required when LIVE_TRADING=true) ---
PRIVATE_KEY=

# --- Polymarket relayer (optional) ---
RELAYER_API_KEY=
RELAYER_API_KEY_ADDRESS=

# --- Core trading ---
ENTRY_WINDOW_END=5
ENTRY_WINDOW_START=180
LIVE_TRADING=false
MAX_CONTRACT_PRICE=0.95
MAX_TRADE_SIZE=10.0
MIN_CONTRACT_PRICE=0.50
MIN_EDGE=0.05
POLYGON_RPC_URL=https://polygon.drpc.org

# --- Risk controls ---
MAX_DAILY_LOSS=20.0
MAX_CONSECUTIVE_LOSSES=5
MAX_DRAWDOWN_HALT=0.40
KELLY_COOLDOWN_LOSSES=3
KELLY_COOLDOWN_SCALE=0.65

# --- Bankroll & sizing ---
STARTING_BANKROLL=33.69
KELLY_MULTIPLIER=0.25
MIN_BET_DOLLARS=2.50

# --- Ruin / drawdown calibration ---
RUIN_TARGET=0.05
RUIN_LEVEL=0.10
MAX_DRAWDOWN_SCALE=0.50

# --- Dashboard ---
PORT=8080
