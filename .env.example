# === Wallet ===
# Your Polygon wallet private key (with or without 0x prefix)
# Run: python setup_wallet.py  to generate a new one
PRIVATE_KEY=

# === Relayer API ===
# Polymarket relayer API key and associated address
RELAYER_API_KEY=
RELAYER_API_KEY_ADDRESS=

# === Polygon RPC ===
# Free public RPCs work but are rate-limited. For production use a paid provider.
# Options: https://polygon.drpc.org  |  https://rpc.ankr.com/polygon  |  Alchemy / Infura
POLYGON_RPC_URL=https://polygon.drpc.org

# === Trading Parameters ===
# Max USDC to spend per single trade (default 2.0)
MAX_TRADE_SIZE=2.0

# Minimum edge required to place a trade (0.0 to 1.0, default 0.05 = 5%)
MIN_EDGE=0.05

# Maximum daily loss in USDC before the bot pauses (default 20.0)
MAX_DAILY_LOSS=20.0

# Maximum number of consecutive losses before pausing (default 5)
MAX_CONSECUTIVE_LOSSES=5

# Seconds before market close to START looking for trades (default 180 = 3 min)
ENTRY_WINDOW_START=180

# Seconds before market close to STOP entering trades (default 5)
ENTRY_WINDOW_END=5

# Price range: only buy contracts priced between these bounds
MIN_CONTRACT_PRICE=0.50
MAX_CONTRACT_PRICE=0.95

# === Mode ===
# Set to "true" to enable live trading. Default is dry-run (paper trading).
LIVE_TRADING=false

# === Web Dashboard ===
# Port for the web dashboard (Railway sets this automatically)
PORT=8080
