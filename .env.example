# === Copy to .env and fill secrets (never commit .env) ===

# --- Core trading (matches typical Railway vars) ---
ENTRY_WINDOW_END=5
ENTRY_WINDOW_START=180
LIVE_TRADING=false
MAX_CONSECUTIVE_LOSSES=5
MAX_CONTRACT_PRICE=0.95
MAX_DAILY_LOSS=20.0
MAX_TRADE_SIZE=2.0
MIN_CONTRACT_PRICE=0.50
MIN_EDGE=0.05
POLYGON_RPC_URL=https://polygon.drpc.org

# --- Wallet / CLOB (required when LIVE_TRADING=true) ---
PRIVATE_KEY=

# --- Polymarket relayer (optional; this repo’s CLOB path does not read these yet) ---
RELAYER_API_KEY=
RELAYER_API_KEY_ADDRESS=

# --- Bankroll & sizing (loaded by src/config.py) ---
STARTING_BANKROLL=33.69
KELLY_MULTIPLIER=0.25
MIN_BET_DOLLARS=0.50

# --- Dashboard ---
PORT=8080
